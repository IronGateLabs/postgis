-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
-- These are reserved for functions where the they are changed to use default args
-- This is installed after the new functions are installed
-- We don't have any of these yet for topology
-- The reason we put these after install is
-- you can't drop a function that is used by sql functions
-- without forcing a drop on those as well which may cause issues with user functions.
-- This allows us to CREATE OR REPLACE those in general topology.sql
-- without dropping them.

DO $BODY$
DECLARE
  rec RECORD;
BEGIN
  FOR rec IN
    WITH updated AS (
      UPDATE topology.topology SET SRID=0 WHERE SRID<0
      RETURNING *
    )
    SELECT * FROM updated
  LOOP
    -- NOTE: these notices will not be shown during extension upgrade
    RAISE NOTICE 'Topology % had SRID<0, updated to the officially unknown SRID value 0', rec.name;
  END LOOP;
END;
$BODY$ LANGUAGE 'plpgsql';

-- Make topology FK constraints DEFERRABLE INITIALLY DEFERRED
-- so that batch SPI operations (used by toTopoGeom, TopoGeo_Add*)
-- are not blocked by per-row FK checks. This also works around a
-- PostgreSQL 19devel regression in the RI fast-path trigger code
-- that crashes when immediate FK triggers fire inside SPI contexts.
-- Changed: 3.7.0
DO $BODY$
DECLARE
  rec RECORD;
BEGIN
  FOR rec IN
    SELECT name FROM topology.topology
  LOOP
    BEGIN
      /* node.face_exists -> face */
      EXECUTE format(
        'ALTER TABLE %I.node DROP CONSTRAINT IF EXISTS face_exists',
        rec.name
      );
      EXECUTE format(
        'ALTER TABLE %I.node ADD CONSTRAINT face_exists'
        ' FOREIGN KEY(containing_face)'
        ' REFERENCES %I.face(face_id)'
        ' DEFERRABLE INITIALLY DEFERRED',
        rec.name, rec.name
      );
      /* edge_data.start_node_exists -> node */
      EXECUTE format(
        'ALTER TABLE %I.edge_data DROP CONSTRAINT IF EXISTS start_node_exists',
        rec.name
      );
      EXECUTE format(
        'ALTER TABLE %I.edge_data ADD CONSTRAINT start_node_exists'
        ' FOREIGN KEY(start_node)'
        ' REFERENCES %I.node(node_id)'
        ' DEFERRABLE INITIALLY DEFERRED',
        rec.name, rec.name
      );
      /* edge_data.end_node_exists -> node */
      EXECUTE format(
        'ALTER TABLE %I.edge_data DROP CONSTRAINT IF EXISTS end_node_exists',
        rec.name
      );
      EXECUTE format(
        'ALTER TABLE %I.edge_data ADD CONSTRAINT end_node_exists'
        ' FOREIGN KEY(end_node)'
        ' REFERENCES %I.node(node_id)'
        ' DEFERRABLE INITIALLY DEFERRED',
        rec.name, rec.name
      );
      /* edge_data.left_face_exists -> face */
      EXECUTE format(
        'ALTER TABLE %I.edge_data DROP CONSTRAINT IF EXISTS left_face_exists',
        rec.name
      );
      EXECUTE format(
        'ALTER TABLE %I.edge_data ADD CONSTRAINT left_face_exists'
        ' FOREIGN KEY(left_face)'
        ' REFERENCES %I.face(face_id)'
        ' DEFERRABLE INITIALLY DEFERRED',
        rec.name, rec.name
      );
      /* edge_data.right_face_exists -> face */
      EXECUTE format(
        'ALTER TABLE %I.edge_data DROP CONSTRAINT IF EXISTS right_face_exists',
        rec.name
      );
      EXECUTE format(
        'ALTER TABLE %I.edge_data ADD CONSTRAINT right_face_exists'
        ' FOREIGN KEY(right_face)'
        ' REFERENCES %I.face(face_id)'
        ' DEFERRABLE INITIALLY DEFERRED',
        rec.name, rec.name
      );
    EXCEPTION WHEN OTHERS THEN
      RAISE NOTICE 'Could not upgrade FK constraints in topology %: %', rec.name, SQLERRM;
    END;
  END LOOP;
END;
$BODY$ LANGUAGE 'plpgsql';

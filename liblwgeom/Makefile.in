srcdir = @srcdir@
builddir = @builddir@
top_builddir = @top_builddir@
prefix = @prefix@
libdir = @libdir@
includedir = @includedir@
exec_prefix = @exec_prefix@

CC = @CC@
CPPFLAGS =  $(RYU_INCLUDE) @CPPFLAGS@ -I$(builddir) -I$(srcdir)
CFLAGS = @CFLAGS@ @PICFLAGS@
LDFLAGS = @LDFLAGS@ @GEOS_LDFLAGS@ @PROJ_LDFLAGS@ @JSON_LDFLAGS@
SHELL = @SHELL@
INSTALL = @INSTALL@
LIBTOOL = @LIBTOOL@

VPATH = $(srcdir):$(builddir)
RYU_INCLUDE = -I$(srcdir)/../deps/ryu/..

SOVER = @POSTGIS_MAJOR_VERSION@.@POSTGIS_MINOR_VERSION@

IFACE_CURRENT = @LIBLWGEOM_CURRENT@
IFACE_AGE = @LIBLWGEOM_AGE@
IFACE_REV = @LIBLWGEOM_REV@

VERSION_INFO = $(IFACE_CURRENT):$(IFACE_REV):$(IFACE_AGE)


YACC=@YACC@
LEX=@LEX@

# Standalone LWGEOM objects
SA_OBJS = \
	stringbuffer.o \
	optionlist.o \
	stringlist.o \
	bytebuffer.o \
	measures.o \
	measures3d.o \
	ptarray.o \
	lookup3.o \
	lwgeom_api.o \
	lwgeom.o \
	lwpoint.o \
	lwline.o \
	lwpoly.o \
	lwtriangle.o \
	lwmpoint.o \
	lwmline.o \
	lwmpoly.o \
	lwboundingcircle.o \
	lwcollection.o \
	lwcircstring.o \
	lwcompound.o \
	lwcurvepoly.o \
	lwmcurve.o \
	lwmsurface.o \
	lwpsurface.o \
	lwtin.o \
	lwout_wkb.o \
	lwin_geojson.o \
	lwin_wkb.o \
	lwin_twkb.o \
	lwiterator.o \
	lwgeom_median.o \
	lwout_wkt.o \
	lwout_twkb.o \
	lwin_wkt_parse.o \
	lwin_wkt_lex.o \
	lwin_wkt.o \
	lwin_encoded_polyline.o \
	lwutil.o \
	lwhomogenize.o \
	intervaltree.o \
	lwalgorithm.o \
	lwstroke.o \
	lwlinearreferencing.o \
	lwprint.o \
	gbox.o \
	gserialized.o \
	gserialized1.o \
	gserialized2.o \
	lwgeodetic.o \
	lwgeodetic_measures.o \
	lwgeodetic_tree.o \
	lwrandom.o \
	lwtree.o \
	lwout_gml.o \
	lwout_kml.o \
	lwout_geojson.o \
	lwout_svg.o \
	lwout_x3d.o \
	lwout_encoded_polyline.o \
	lwgeom_debug.o \
	lwgeom_geos.o \
	lwgeom_geos_clean.o \
	lwgeom_geos_cluster.o \
	lwgeom_geos_node.o \
	lwgeom_geos_split.o \
	topo/lwgeom_topo.o \
	topo/lwgeom_topo_polygonizer.o \
	topo/lwt_edgeend.o \
	topo/lwt_edgeend_star.o \
	topo/lwt_node_edges.o \
	lwgeom_transform.o \
	lwgeom_eci.o \
	lwgeom_wrapx.o \
	lwunionfind.o \
	effectivearea.o \
	lwchaikins.o \
	lwmval.o \
	lwkmeans.o \
	varint.o \
	lwgeom_remove_irrelevant_points_for_view.o

NM_OBJS = \
	lwspheroid.o

ifeq (@SFCGAL@,sfcgal)
CFLAGS += @SFCGAL_CPPFLAGS@
LDFLAGS += @SFCGAL_LDFLAGS@
SA_OBJS += lwgeom_sfcgal.o
endif

# Acceleration dispatch (always built, contains runtime detection + scalar fallback)
SA_OBJS += lwgeom_accel.o lwgeom_gpu.o

# Vendored ERFA subset for IAU 2006/2000A precession-nutation.
# See liblwgeom/erfa/ERFA-VERSION.txt for upstream version and license.
# Compiled with relaxed warnings since upstream code uses standard-mandated
# function signatures that may have unused parameters. All other fork code
# keeps -Wall -Werror.
ERFA_OBJS = \
	erfa/anp.o \
	erfa/bi00.o \
	erfa/bpn2xy.o \
	erfa/c2i06a.o \
	erfa/c2ixys.o \
	erfa/c2t06a.o \
	erfa/c2tcio.o \
	erfa/cp.o \
	erfa/cr.o \
	erfa/era00.o \
	erfa/fad03.o \
	erfa/fae03.o \
	erfa/faf03.o \
	erfa/faju03.o \
	erfa/fal03.o \
	erfa/falp03.o \
	erfa/fama03.o \
	erfa/fame03.o \
	erfa/fane03.o \
	erfa/faom03.o \
	erfa/fapa03.o \
	erfa/fasa03.o \
	erfa/faur03.o \
	erfa/fave03.o \
	erfa/fw2m.o \
	erfa/fw2xy.o \
	erfa/gmst06.o \
	erfa/ir.o \
	erfa/nut00a.o \
	erfa/nut06a.o \
	erfa/obl06.o \
	erfa/pfw06.o \
	erfa/pmat76.o \
	erfa/pnm06a.o \
	erfa/pom00.o \
	erfa/pr00.o \
	erfa/prec76.o \
	erfa/rx.o \
	erfa/rxr.o \
	erfa/ry.o \
	erfa/rz.o \
	erfa/s06.o \
	erfa/sp00.o \
	erfa/tr.o \
	erfa/xy06.o \
	erfa/xys06a.o

SA_OBJS += $(ERFA_OBJS)

# SIMD-accelerated files (compiled with ISA-specific flags)
ACCEL_OBJS =
ifeq (@HAVE_AVX2@,yes)
ACCEL_OBJS += accel/rotate_z_avx2.o accel/rad_convert_avx2.o
endif
ifeq (@HAVE_AVX512@,yes)
ACCEL_OBJS += accel/rotate_z_avx512.o
endif
ifeq (@HAVE_NEON@,yes)
ACCEL_OBJS += accel/rotate_z_neon.o accel/rad_convert_neon.o
endif

# GPU backend files
NVCC = @NVCC@
HIPCC = @HIPCC@
ICPX = @ICPX@
ifeq (@HAVE_CUDA@,yes)
ACCEL_OBJS += accel/gpu_cuda.o
CPPFLAGS += @CUDA_CFLAGS@
LDFLAGS += @CUDA_LDFLAGS@
endif
ifeq (@HAVE_ROCM@,yes)
ACCEL_OBJS += accel/gpu_rocm.o
CPPFLAGS += @ROCM_CFLAGS@
LDFLAGS += @ROCM_LDFLAGS@
endif
ifeq (@HAVE_ONEAPI@,yes)
ACCEL_OBJS += accel/gpu_oneapi.o
CPPFLAGS += @ONEAPI_CFLAGS@
LDFLAGS += @ONEAPI_LDFLAGS@
endif
ifeq (@HAVE_METAL@,yes)
METAL_COMPILER = @METAL_COMPILER@
METALLIB_TOOL = @METALLIB_TOOL@
ACCEL_OBJS += accel/gpu_metal.o
LDFLAGS += @METAL_LDFLAGS@
endif

LDFLAGS += -no-undefined

LT_SA_OBJS = $(SA_OBJS:.o=.lo)
LT_NM_OBJS = $(NM_OBJS:.o=.lo)
LT_ACCEL_OBJS = $(ACCEL_OBJS:.o=.lo)
LT_OBJS = $(LT_SA_OBJS) $(LT_NM_OBJS) $(LT_ACCEL_OBJS)

SA_HEADERS = \
	bytebuffer.h \
	effectivearea.h \
	liblwgeom.h \
	liblwgeom_internal.h \
	lwgeodetic.h \
	lwgeodetic_tree.h \
	topo/liblwgeom_topo.h \
	topo/liblwgeom_topo_internal.h \
	topo/lwt_edgeend.h \
	topo/lwt_edgeend_star.h \
	topo/lwt_node_edges.h \
	lwgeom_log.h \
	lwgeom_geos.h \
	lwgeom_log.h \
	lwgeom_sfcgal.h \
	lwinline.h \
	intervaltree.h \
	lwin_wkt.h \
	lwin_wkt_parse.h \
	lwout_twkb.h \
	lwrandom.h \
	lwtree.h \
	measures3d.h \
	measures.h \
	stringbuffer.h \
	varint.h \
	lwgeom_remove_irrelevant_points_for_view.h \
	lwgeom_accel.h \
	lwgeom_gpu.h

all: liblwgeom.la

install:

uninstall:

# Make all objects depend upon postgis_config.h and postgis_revision.h
$(LT_OBJS): ../postgis_config.h ../postgis_revision.h $(SA_HEADERS)

../postgis_revision.h:
	$(MAKE) -C .. postgis_revision.h


RYU_LIBPATH = ../deps/ryu/@RYU_LIB@
$(RYU_LIBPATH): ../deps/ryu/d2s.c
	$(MAKE) -C ../deps/ryu @RYU_LIB@

liblwgeom.la: $(LT_OBJS) $(RYU_LIBPATH)
	$(LIBTOOL) --tag=CC --mode=link $(CC) -rpath $(libdir) $(LT_OBJS) $(RYU_LIBPATH)\
             -release $(SOVER) -version-info $(VERSION_INFO) $(LDFLAGS) -static -o $@

maintainer-clean: clean
	rm -f lwin_wkt_lex.c
	rm -f lwin_wkt_parse.h
	rm -f lwin_wkt_parse.c

clean:
	$(MAKE) -C cunit clean
	$(MAKE) -C ../deps/ryu clean
	rm -f $(LT_OBJS) $(SA_OBJS) $(NM_OBJS)
	rm -f liblwgeom.la
	rm -rf .libs
	rm -rf topo/.libs
	rm -rf accel/.libs accel/*.o accel/*.lo
	rm -f accel/*.air accel/*.metallib accel/gpu_metal_kernels_metallib.h
	rm -rf erfa/.libs erfa/*.o erfa/*.lo

distclean: clean
	$(MAKE) -C cunit distclean
	rm -f liblwgeom.h Makefile

check: check-unit

check-regress:

.PHONY: check-unit
check-unit: liblwgeom.la
	$(MAKE) -C cunit check

# Command to build each of the .lo files
$(LT_SA_OBJS): %.lo: %.c
	$(LIBTOOL) --mode=compile $(CC) $(CPPFLAGS) $(CFLAGS) -c -o $@ $<

$(LT_NM_OBJS): %.lo: %.c
	$(LIBTOOL) --mode=compile $(CC) $(CPPFLAGS) $(CFLAGS) -c -o $@ $<

lwin_wkt_parse.c lwin_wkt_parse.h: lwin_wkt_parse.y
	@test -n "$(YACC)" || { \
			echo "No yacc found, cannot build parser" >&2; \
			false; \
	}
	$(YACC) -p wkt_yy -o'lwin_wkt_parse.c' -d $<

lwin_wkt_lex.c: lwin_wkt_lex.l
	@test -n "$(LEX)" || { \
			echo "No lex found, cannot build parser" >&2; \
			false; \
	}
	$(LEX) -i $<

liblwgeom.h: liblwgeom.h.in
	cd $(top_builddir) && ./config.status

# Vendored ERFA compilation rule (relaxed warnings for upstream code)
# ERFA functions follow IAU standard signatures that may have unused params.
# We disable those specific warnings for the vendored subdirectory only;
# all other fork code keeps -Wall -Werror untouched.
# IEEE-754 standard FP math is required for ERFA accuracy; do not enable
# -ffast-math here.
$(ERFA_OBJS:.o=.lo): erfa/%.lo: erfa/%.c
	@mkdir -p erfa
	$(LIBTOOL) --mode=compile $(CC) $(CPPFLAGS) $(CFLAGS) \
		-Wno-unused-parameter -Wno-unused-variable -Wno-unused-but-set-variable \
		-c -o $@ $<

# SIMD-specific compilation rules (need ISA-specific flags)
accel/rotate_z_avx2.lo: accel/rotate_z_avx2.c
	@mkdir -p accel
	$(LIBTOOL) --mode=compile $(CC) $(CPPFLAGS) $(CFLAGS) @AVX2_CFLAGS@ -c -o $@ $<

accel/rad_convert_avx2.lo: accel/rad_convert_avx2.c
	@mkdir -p accel
	$(LIBTOOL) --mode=compile $(CC) $(CPPFLAGS) $(CFLAGS) @AVX2_CFLAGS@ -c -o $@ $<

accel/rotate_z_avx512.lo: accel/rotate_z_avx512.c
	@mkdir -p accel
	$(LIBTOOL) --mode=compile $(CC) $(CPPFLAGS) $(CFLAGS) @AVX512_CFLAGS@ -c -o $@ $<

accel/rotate_z_neon.lo: accel/rotate_z_neon.c
	@mkdir -p accel
	$(LIBTOOL) --mode=compile $(CC) $(CPPFLAGS) $(CFLAGS) -c -o $@ $<

accel/rad_convert_neon.lo: accel/rad_convert_neon.c
	@mkdir -p accel
	$(LIBTOOL) --mode=compile $(CC) $(CPPFLAGS) $(CFLAGS) -c -o $@ $<

# GPU compilation rules
accel/gpu_cuda.lo: accel/gpu_cuda.cu
	@mkdir -p accel
	$(NVCC) -c -Xcompiler "$(CPPFLAGS) $(CFLAGS)" -o accel/gpu_cuda.o $<

accel/gpu_rocm.lo: accel/gpu_rocm.hip
	@mkdir -p accel
	$(HIPCC) -c $(CPPFLAGS) $(CFLAGS) -o accel/gpu_rocm.o $<

accel/gpu_oneapi.lo: accel/gpu_oneapi.cpp
	@mkdir -p accel
	$(ICPX) -fsycl -c $(CPPFLAGS) $(CFLAGS) -o accel/gpu_oneapi.o $<

# Metal GPU compilation rules (macOS only)
ifeq (@HAVE_METAL@,yes)
accel/gpu_metal_kernels.air: accel/gpu_metal_kernels.metal
	@mkdir -p accel
	$(METAL_COMPILER) -c $< -o $@

accel/gpu_metal_kernels.metallib: accel/gpu_metal_kernels.air
	$(METALLIB_TOOL) $< -o $@

accel/gpu_metal_kernels_metallib.h: accel/gpu_metal_kernels.metallib
	xxd -i $< > $@

accel/gpu_metal.o: accel/gpu_metal.m accel/gpu_metal_kernels_metallib.h
	@mkdir -p accel
	$(CC) -ObjC $(CPPFLAGS) $(CFLAGS) -c $< -o $@

accel/gpu_metal.lo: accel/gpu_metal.m accel/gpu_metal_kernels_metallib.h
	@mkdir -p accel
	$(LIBTOOL) --mode=compile $(CC) -ObjC $(CPPFLAGS) $(CFLAGS) -c -o $@ $<
endif
